<!DOCTYPE html>
<!--
  ============================================================
  Página de regalo — hecha con cariño.

  CÓMO AÑADIR UNA CARTA NUEVA:
  Busca el array "CARTAS" dentro de <script>. Copia un bloque,
  pégalo antes del cierre "]" y cambia fecha / título / contenido.
  El candado, la cuenta atrás y el botón de abrir se generan solos.
  ============================================================
-->
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="theme-color" content="#10122A">
<title>Para ti 💌</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>💌</text></svg>">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,600&family=Caveat:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg-deep:#0F1229;
    --bg-deep2:#241B3A;
    --gold:#E7B95C;
    --gold-soft:#F0D28E;
    --rose:#E8828F;
    --paper:#FBF3E4;
    --paper-shadow:#e8ddc4;
    --ink:#3B2A24;
    --text-soft:#DAD5EA;
    --text-mut:#9C97B8;
    --max:640px;
  }

  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:linear-gradient(180deg,var(--bg-deep) 0%,var(--bg-deep2) 55%,#1a1430 100%);
    color:var(--text-soft);
    font-family:'Inter',sans-serif;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
    position:relative;
  }

  h1,h2,h3{font-family:'Playfair Display',serif; margin:0; font-weight:600;}
  .script{font-family:'Caveat',cursive;}
  a{color:inherit;}

  .wrap{max-width:var(--max); margin:0 auto; padding:0 24px;}

  /* ---------- foto de fondo ---------- */
  .bg-photo{
    position:fixed; inset:0; z-index:-1;
    background-image:url('data:image/jpeg;base64,');
    background-size:cover;
    background-position:center;
    opacity:.72; /* opacidad media-alta */
  }

  /* ---------- starfield ---------- */
  .stars{position:fixed; inset:0; pointer-events:none; z-index:0; overflow:hidden;}
  .star{
    position:absolute; background:#fff; border-radius:50%;
    opacity:.4; animation:twinkle 4s ease-in-out infinite;
  }
  @keyframes twinkle{
    0%,100%{opacity:.15; transform:scale(1);}
    50%{opacity:.9; transform:scale(1.3);}
  }

  section{position:relative; z-index:1;}

  /* ---------- reveal on scroll ---------- */
  .reveal{opacity:0; transform:translateY(18px); transition:opacity .8s ease, transform .8s ease;}
  .reveal.in-view{opacity:1; transform:translateY(0);}

  /* ---------- hero ---------- */
  .hero{
    min-height:100svh; display:flex; flex-direction:column;
    align-items:center; justify-content:center; text-align:center;
    padding:80px 24px 40px;
  }
  .eyebrow{
    text-transform:uppercase; letter-spacing:.2em; font-size:.72rem;
    color:var(--gold-soft); margin-bottom:18px; font-weight:600;
    text-shadow:0 1px 8px rgba(0,0,0,.5);
  }
  .hero h1{
    font-family:'Caveat',cursive; font-weight:700;
    font-size:clamp(2.8rem,11vw,4.4rem);
    color:#fff; line-height:1.05; margin-bottom:14px;
    text-shadow:0 2px 18px rgba(0,0,0,.55);
  }
  .hero p{
    color:var(--text-soft); max-width:420px; margin:0 auto; line-height:1.6;
    font-size:.98rem;
    text-shadow:0 1px 10px rgba(0,0,0,.55);
  }

  .counter{
    margin-top:44px; display:flex; gap:10px; justify-content:center; flex-wrap:wrap;
  }
  .counter .unit{
    background:rgba(255,255,255,.03);
    border:1px solid rgba(255,255,255,.14);
    backdrop-filter:blur(10px);
    -webkit-backdrop-filter:blur(10px);
    border-radius:14px;
    width:72px; padding:14px 0;
    display:flex; flex-direction:column; align-items:center; gap:4px;
    box-shadow:0 4px 20px rgba(0,0,0,.25);
  }
  .counter .num{
    font-family:'Playfair Display',serif; font-size:1.7rem; font-weight:700; color:var(--gold);
    font-variant-numeric:tabular-nums;
  }
  .counter .lbl{font-size:.62rem; text-transform:uppercase; letter-spacing:.08em; color:var(--text-mut);}
  .since{margin-top:16px; font-size:.78rem; color:var(--text-mut); text-shadow:0 1px 8px rgba(0,0,0,.5);}

  .scrollcue{
    margin-top:56px; color:var(--text-mut); font-size:1.3rem;
    animation:bob 2.4s ease-in-out infinite;
  }
  @keyframes bob{0%,100%{transform:translateY(0);}50%{transform:translateY(8px);}}

  /* ---------- section heading ---------- */
  .section-head{text-align:center; padding:70px 24px 8px;}
  .section-head .eyebrow{margin-bottom:10px;}
  .section-head h2{color:#fff; font-size:clamp(1.7rem,6vw,2.1rem); text-shadow:0 2px 14px rgba(0,0,0,.5);}
  .section-head p{color:var(--text-soft); font-size:.9rem; margin-top:10px; max-width:400px; margin-left:auto; margin-right:auto; line-height:1.5; text-shadow:0 1px 8px rgba(0,0,0,.5);}

  /* ---------- playlist ---------- */
  .player-card{
    background:rgba(255,255,255,.03);
    border:1px solid rgba(255,255,255,.15);
    backdrop-filter:blur(12px);
    -webkit-backdrop-filter:blur(12px);
    border-radius:22px; padding:26px 22px; margin-top:28px;
    box-shadow:0 8px 30px rgba(0,0,0,.25);
  }
  .player-top{display:flex; align-items:center; gap:18px;}
  .vinyl{
    width:72px; height:72px; border-radius:50%; flex:none;
    background:radial-gradient(circle at center, #1a1430 0 14%, var(--gold) 15% 17%, #1a1430 18% 100%);
    border:3px solid rgba(255,255,255,.12);
    animation:spin 3.5s linear infinite; animation-play-state:paused;
  }
  .vinyl.spinning{animation-play-state:running;}
  @keyframes spin{to{transform:rotate(360deg);}}
  .track-info{min-width:0;}
  .track-info .t-title{font-weight:600; color:#fff; font-size:1rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;}
  .track-info .t-artist{font-size:.8rem; color:var(--text-mut); margin-top:2px;}

  .progress-row{display:flex; align-items:center; gap:10px; margin-top:20px;}
  .time{font-size:.68rem; color:var(--text-mut); font-variant-numeric:tabular-nums; width:34px;}
  .time.right{text-align:right;}
  input[type=range]{
    -webkit-appearance:none; appearance:none; flex:1; height:4px; border-radius:4px;
    background:rgba(255,255,255,.15); outline:none; cursor:pointer;
  }
  input[type=range]::-webkit-slider-thumb{
    -webkit-appearance:none; width:13px; height:13px; border-radius:50%;
    background:var(--gold); cursor:pointer; box-shadow:0 0 0 4px rgba(231,185,92,.18);
  }
  input[type=range]::-moz-range-thumb{
    width:13px; height:13px; border-radius:50%; background:var(--gold); border:none;
  }

  .controls{display:flex; align-items:center; justify-content:center; gap:26px; margin-top:18px;}
  .controls button{
    background:none; border:none; color:#fff; cursor:pointer; padding:6px;
    display:flex; align-items:center; justify-content:center;
  }
  .controls svg{width:20px; height:20px; fill:currentColor;}
  .play-btn{
    width:52px; height:52px; border-radius:50%;
    background:rgba(231,185,92,.5) !important;
    border:1px solid rgba(231,185,92,.7) !important;
    backdrop-filter:blur(8px);
    -webkit-backdrop-filter:blur(8px);
    color:#fff !important;
  }
  .play-btn svg{width:22px; height:22px;}

  .tracklist{margin-top:22px; display:flex; flex-direction:column; gap:6px;}
  .track-row{
    display:flex; align-items:center; gap:12px; padding:10px 12px; border-radius:12px;
    cursor:pointer; transition:background .2s ease;
  }
  .track-row:hover{background:rgba(255,255,255,.05);}
  .track-row.active{background:rgba(231,185,92,.10); border:1px solid rgba(231,185,92,.25); backdrop-filter:blur(6px);}
  .track-row .idx{font-size:.75rem; color:var(--text-mut); width:16px; font-variant-numeric:tabular-nums;}
  .track-row.active .idx{color:var(--gold);}
  .track-row .names{flex:1; min-width:0;}
  .track-row .n-title{font-size:.88rem; color:#fff; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;}
  .track-row .n-artist{font-size:.72rem; color:var(--text-mut);}
  .track-row .eq{width:14px; height:12px; display:none; align-items:flex-end; gap:2px;}
  .track-row.active .eq{display:flex;}
  .track-row .eq span{width:3px; background:var(--gold); animation:eq 0.9s ease-in-out infinite;}
  .track-row .eq span:nth-child(1){height:40%; animation-delay:0s;}
  .track-row .eq span:nth-child(2){height:100%; animation-delay:.2s;}
  .track-row .eq span:nth-child(3){height:65%; animation-delay:.4s;}
  @keyframes eq{0%,100%{transform:scaleY(.4);} 50%{transform:scaleY(1);}}

  /* mini player */
  .miniplayer{
    position:fixed; left:14px; right:14px; bottom:14px; z-index:40;
    background:rgba(20,17,40,.5); backdrop-filter:blur(16px);
    -webkit-backdrop-filter:blur(16px);
    border:1px solid rgba(255,255,255,.14); border-radius:16px;
    padding:10px 14px; display:flex; align-items:center; gap:12px;
    max-width:400px; margin:0 auto;
    transform:translateY(120%); transition:transform .35s ease;
    box-shadow:0 10px 30px rgba(0,0,0,.35);
  }
  .miniplayer.show{transform:translateY(0);}
  .miniplayer .mini-vinyl{width:32px; height:32px; flex:none;}
  .miniplayer .mini-info{flex:1; min-width:0;}
  .miniplayer .mini-info .n-title{font-size:.82rem; color:#fff; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;}
  .miniplayer .mini-info .n-artist{font-size:.68rem; color:var(--text-mut);}
  .miniplayer button{background:none; border:none; color:#fff; cursor:pointer; padding:6px;}
  .miniplayer svg{width:18px; height:18px; fill:currentColor;}

  /* ---------- cartas timeline ---------- */
  .timeline{position:relative; margin-top:34px; padding-left:34px;}
  .timeline::before{
    content:''; position:absolute; left:11px; top:6px; bottom:6px; width:2px;
    background:repeating-linear-gradient(180deg, rgba(231,185,92,.5) 0 6px, transparent 6px 12px);
  }
  .carta{position:relative; margin-bottom:22px;}
  .carta::before{
    content:''; position:absolute; left:-34px; top:18px; width:12px; height:12px; border-radius:50%;
    background:var(--bg-deep); border:2px solid var(--gold); z-index:2;
  }
  .carta.locked::before{border-color:var(--text-mut);}
  .carta-card{
    background:rgba(255,255,255,.03); border:1px solid rgba(255,255,255,.15);
    backdrop-filter:blur(10px); -webkit-backdrop-filter:blur(10px);
    border-radius:16px; padding:16px 18px; display:flex; align-items:center; gap:14px;
    cursor:pointer; transition:background .2s ease, transform .2s ease;
  }
  .carta-card:hover{background:rgba(255,255,255,.06);}
  .carta.locked .carta-card{cursor:default;}
  .carta.locked .carta-card:hover{background:rgba(255,255,255,.03);}
  .carta-icon{font-size:1.5rem; flex:none;}
  .carta-body{flex:1; min-width:0;}
  .carta-date{font-size:.68rem; text-transform:uppercase; letter-spacing:.06em; color:var(--gold-soft);}
  .carta.locked .carta-date{color:var(--text-mut);}
  .carta-title{font-family:'Playfair Display',serif; font-size:1rem; color:#fff; margin-top:2px;}
  .carta.locked .carta-title{color:var(--text-mut);}
  .carta-sub{font-size:.74rem; color:var(--text-mut); margin-top:3px;}
  .timeline-note{text-align:center; color:var(--text-mut); font-size:.8rem; margin-top:26px; text-shadow:0 1px 8px rgba(0,0,0,.5);}

  /* ---------- modal ---------- */
  .modal-back{
    position:fixed; inset:0; background:rgba(10,8,20,.75); backdrop-filter:blur(4px);
    display:flex; align-items:center; justify-content:center; padding:20px; z-index:100;
    opacity:0; pointer-events:none; transition:opacity .25s ease;
  }
  .modal-back.show{opacity:1; pointer-events:auto;}
  .letter{
    background:var(--paper); color:var(--ink); border-radius:6px; max-width:440px; width:100%;
    max-height:82vh; overflow-y:auto; padding:34px 28px 30px; position:relative;
    box-shadow:0 20px 60px rgba(0,0,0,.5);
    transform:translateY(24px) scale(.97); transition:transform .3s ease;
  }
  .modal-back.show .letter{transform:translateY(0) scale(1);}
  .letter-date{font-size:.72rem; text-transform:uppercase; letter-spacing:.08em; color:#8a7458;}
  .letter h3{font-family:'Playfair Display',serif; margin-top:8px; font-size:1.35rem; color:var(--ink);}
  .letter-body{font-family:'Caveat',cursive; font-size:1.35rem; line-height:1.5; margin-top:16px; white-space:pre-wrap;}
  .letter-close{
    position:absolute; top:14px; right:14px; background:none; border:none; cursor:pointer;
    font-size:1.1rem; color:#8a7458; width:32px; height:32px; border-radius:50%;
  }
  .letter-close:hover{background:rgba(0,0,0,.06);}

  /* ---------- closing ---------- */
  .closing{padding:90px 24px 40px; text-align:center;}
  .closing h2{
    font-family:'Caveat',cursive; font-weight:700; color:#fff;
    font-size:clamp(2.2rem,9vw,3rem); line-height:1.15;
    text-shadow:0 2px 18px rgba(0,0,0,.55);
  }
  .closing .star-ic{font-size:1.6rem; display:block; margin-bottom:10px;}

  .special-note{
    margin:34px auto 0; max-width:420px; background:rgba(232,130,143,.07);
    border:1px solid rgba(232,130,143,.3);
    backdrop-filter:blur(10px); -webkit-backdrop-filter:blur(10px);
    border-radius:18px; padding:22px 20px;
  }
  .special-note .sn-title{color:var(--rose); font-weight:600; font-size:.85rem;}
  .special-note p{font-size:.85rem; color:var(--text-soft); line-height:1.55; margin:8px 0 0;}
  .special-note .sn-count{margin-top:14px; font-size:.72rem; color:var(--text-mut);}
  .special-note .sn-count b{color:var(--gold); font-variant-numeric:tabular-nums;}

  footer{text-align:center; padding:30px 24px 110px; color:var(--text-mut); font-size:.75rem; text-shadow:0 1px 8px rgba(0,0,0,.5);}

  @media (prefers-reduced-motion: reduce){
    html{scroll-behavior:auto;}
    .star,.scrollcue,.vinyl,.track-row .eq span{animation:none !important;}
    .reveal{transition:none;}
  }

  @media (min-width:700px){
    .wrap{padding:0 24px;}
  }
</style>
</head>
<body>

<div class="bg-photo"></div>
<div class="stars" id="stars"></div>

<!-- ===================== HERO ===================== -->
<section class="hero">
  <div class="eyebrow">un rincón solo para ti</div>
  <h1>Para mi persona<br>favorita</h1>
  <p>Aquí guardo nuestra música, los días que llevamos juntos contados uno a uno, y algunas cartas que te iré dejando por el camino.</p>

  <div class="counter" id="counter">
    <div class="unit"><span class="num" id="c-days">0</span><span class="lbl">días</span></div>
    <div class="unit"><span class="num" id="c-hours">0</span><span class="lbl">horas</span></div>
    <div class="unit"><span class="num" id="c-mins">0</span><span class="lbl">min</span></div>
    <div class="unit"><span class="num" id="c-secs">0</span><span class="lbl">seg</span></div>
  </div>
  <div class="since">juntos desde el 10 de noviembre de 2024</div>

  <div class="scrollcue">⌄</div>
</section>

<!-- ===================== PLAYLIST ===================== -->
<section id="playlist">
  <div class="section-head reveal">
    <div class="eyebrow">🎵 playlist</div>
    <h2>Nuestra playlist</h2>
    <p>Las canciones que tenemos guardadas aquí, solo para nosotros.</p>
  </div>

  <div class="wrap">
    <div class="player-card reveal">
      <div class="player-top">
        <div class="vinyl" id="vinyl"></div>
        <div class="track-info">
          <div class="t-title" id="now-title">—</div>
          <div class="t-artist" id="now-artist">—</div>
        </div>
      </div>

      <div class="progress-row">
        <span class="time" id="time-cur">0:00</span>
        <input type="range" id="seek" value="0" min="0" max="100" step="1">
        <span class="time right" id="time-dur">0:00</span>
      </div>

      <div class="controls">
        <button id="btn-prev" aria-label="Canción anterior">
          <svg viewBox="0 0 24 24"><path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"/></svg>
        </button>
        <button id="btn-play" class="play-btn" aria-label="Reproducir">
          <svg id="icon-play" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          <svg id="icon-pause" viewBox="0 0 24 24" style="display:none"><path d="M6 5h4v14H6zm8 0h4v14h-4z"/></svg>
        </button>
        <button id="btn-next" aria-label="Siguiente canción">
          <svg viewBox="0 0 24 24"><path d="M16 6h2v12h-2zM6 18l8.5-6L6 6z"/></svg>
        </button>
      </div>

      <div class="tracklist" id="tracklist"></div>
    </div>
  </div>
</section>

<!-- ===================== CARTAS ===================== -->
<section id="cartas">
  <div class="section-head reveal">
    <div class="eyebrow">💌 cartas</div>
    <h2>Cartas para ti</h2>
    <p>Algunas ya se pueden abrir. Otras tendrán que esperar un poco más.</p>
  </div>
  <div class="wrap">
    <div class="timeline reveal" id="timeline"></div>
    <div class="timeline-note">(seguiré dejando más cartas aquí con el tiempo)</div>
  </div>
</section>

<!-- ===================== CIERRE ===================== -->
<section class="closing reveal">
  <span class="star-ic">🌠</span>
  <h2>Gracias por ser mi<br>persona favorita.</h2>

  <div class="special-note">
    <div class="sn-title">💫 GUARDA ESTA FECHA</div>
    <p>El 10 de noviembre de 2026 esta página va a cambiar. Hay algo importante que quiero decirte ese día — vuelve a abrir esto cuando llegue.</p>
    <div class="sn-count">Faltan <b id="special-days">—</b> días</div>
  </div>
</section>

<footer>hecho con cariño, para ti 🤍</footer>

<!-- ===================== MODAL CARTA ===================== -->
<div class="modal-back" id="modal">
  <div class="letter" role="dialog" aria-modal="true" aria-labelledby="letter-title">
    <button class="letter-close" id="letter-close" aria-label="Cerrar">✕</button>
    <div class="letter-date" id="letter-date"></div>
    <h3 id="letter-title"></h3>
    <div class="letter-body" id="letter-body"></div>
  </div>
</div>

<!-- ===================== MINI PLAYER ===================== -->
<div class="miniplayer" id="miniplayer">
  <div class="vinyl mini-vinyl" id="mini-vinyl"></div>
  <div class="mini-info">
    <div class="n-title" id="mini-title">—</div>
    <div class="n-artist" id="mini-artist">—</div>
  </div>
  <button id="mini-play" aria-label="Reproducir">
    <svg id="mini-icon-play" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
    <svg id="mini-icon-pause" viewBox="0 0 24 24" style="display:none"><path d="M6 5h4v14H6zm8 0h4v14h-4z"/></svg>
  </button>
</div>

<script>
/* ============================================================
   ✉️  CÓMO AÑADIR UNA CARTA NUEVA
   Copia un bloque de los de abajo, pégalo antes del "]" y cambia:
   - fecha:     "AAAA-MM-DD"  → día en que se desbloquea
   - titulo:    el título que quieras
   - contenido: el texto de la carta (puedes usar varias líneas)
   No hay que tocar nada más. El candado y la cuenta atrás se
   generan solos según la fecha.
   ============================================================ */
const CARTAS = [
  {
    fecha: "2024-11-10",
    titulo: "La primera, para cuando la abras",
    contenido: `Si estás leyendo esto es porque por fin te enseñé este rincón que llevaba tiempo preparando para ti.

No es gran cosa a primera vista: un contador, unas canciones, un par de cartas. Pero cada parte la fui armando pensando en ti, así que para mí sí es gran cosa.

Aquí vas a encontrar la música que nos gusta, los días exactos que llevamos juntos desde el 10 de noviembre de 2024, y cartas que te iré dejando poco a poco. Algunas las vas a poder abrir hoy mismo. Otras tendrán que esperar.

Gracias por estar aquí, por dejarme quererte y por hacerlo tan fácil. Esto es solo el principio de lo que quiero contarte.`
  },
  {
    fecha: "2026-08-10",
    titulo: "Todavía no tiene título",
    contenido: `✏️ Esta carta está esperando a que la escribas. Sustituye este texto por lo que de verdad quieras decirle antes de que llegue la fecha.`
  },
  {
    fecha: "2026-09-10",
    titulo: "Todavía no tiene título",
    contenido: `✏️ Otra carta más por escribir. Cámbiala cuando quieras.`
  },
  {
    fecha: "2026-10-10",
    titulo: "Todavía no tiene título",
    contenido: `✏️ Última de momento — puedes añadir más copiando este bloque.`
  },
];

const START_DATE   = parseLocalDate("2024-11-10");
const SPECIAL_DATE = parseLocalDate("2026-11-10");
const REDUCED_MOTION = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

function parseLocalDate(str){
  const [y,m,d] = str.split('-').map(Number);
  return new Date(y, m-1, d, 0, 0, 0);
}

function fmtFechaLarga(date){
  return date.toLocaleDateString('es-ES', {day:'numeric', month:'long', year:'numeric'});
}

/* ---------- starfield ---------- */
(function buildStars(){
  const container = document.getElementById('stars');
  const n = 55;
  for(let i=0;i<n;i++){
    const s = document.createElement('div');
    s.className = 'star';
    const size = (Math.random()*2 + 1).toFixed(1);
    s.style.width = size + 'px';
    s.style.height = size + 'px';
    s.style.left = (Math.random()*100) + '%';
    s.style.top = (Math.random()*100) + '%';
    if(!REDUCED_MOTION){
      s.style.animationDuration = (3 + Math.random()*4).toFixed(1) + 's';
      s.style.animationDelay = (Math.random()*4).toFixed(1) + 's';
    } else {
      s.style.opacity = '0.5';
      s.style.animation = 'none';
    }
    container.appendChild(s);
  }
})();

function pad(n){ return String(n).padStart(2,'0'); }

/* ---------- cartas / timeline (va ANTES del contador: el
   contador refresca los candados y necesita que cartaEls ya
   exista para no romperse al cargar la página) ---------- */
const timelineEl = document.getElementById('timeline');
let cartaEls = [];

function buildTimeline(){
  CARTAS.forEach((carta, i) => {
    const fecha = parseLocalDate(carta.fecha);
    const unlocked = new Date() >= fecha;

    const item = document.createElement('div');
    item.className = 'carta' + (unlocked ? '' : ' locked');

    const card = document.createElement('div');
    card.className = 'carta-card';
    card.innerHTML = `
      <div class="carta-icon">${unlocked ? '💌' : '🔒'}</div>
      <div class="carta-body">
        <div class="carta-date">${fmtFechaLarga(fecha)}</div>
        <div class="carta-title">${unlocked ? carta.titulo : 'Carta bloqueada'}</div>
        <div class="carta-sub sub-text"></div>
      </div>
    `;
    if(unlocked){
      card.addEventListener('click', () => openLetter(carta, fecha));
    }
    item.appendChild(card);
    timelineEl.appendChild(item);
    cartaEls.push({el:item, sub:card.querySelector('.sub-text'), fecha, unlocked, carta});
  });
  refreshLockStates();
}

function refreshLockStates(){
  const now = new Date();
  cartaEls.forEach(ref => {
    if(ref.unlocked){
      ref.sub.textContent = 'toca para abrir';
    } else {
      const remain = ref.fecha - now;
      const remDays = Math.max(0, Math.ceil(remain / 86400000));
      ref.sub.textContent = remDays <= 0 ? 'se abre hoy' : `se abre en ${remDays} día${remDays===1?'':'s'}`;
    }
  });
}
buildTimeline();

/* ---------- contador principal + cuenta especial ---------- */
function tickCounters(){
  const now = new Date();

  // tiempo juntos
  let diff = now - START_DATE;
  const days = Math.floor(diff / 86400000);
  const hours = Math.floor((diff % 86400000) / 3600000);
  const mins = Math.floor((diff % 3600000) / 60000);
  const secs = Math.floor((diff % 60000) / 1000);
  document.getElementById('c-days').textContent = days;
  document.getElementById('c-hours').textContent = pad(hours);
  document.getElementById('c-mins').textContent = pad(mins);
  document.getElementById('c-secs').textContent = pad(secs);

  // cuenta atrás a la fecha especial
  const remain = SPECIAL_DATE - now;
  const remainDays = Math.max(0, Math.ceil(remain / 86400000));
  document.getElementById('special-days').textContent = remainDays;

  // recalcular candados de cartas (por si el usuario deja la pestaña abierta)
  refreshLockStates();
}
setInterval(tickCounters, 1000);
tickCounters();

/* ---------- modal ---------- */
const modal = document.getElementById('modal');
let lastFocused = null;

function openLetter(carta, fecha){
  lastFocused = document.activeElement;
  document.getElementById('letter-date').textContent = fmtFechaLarga(fecha);
  document.getElementById('letter-title').textContent = carta.titulo;
  document.getElementById('letter-body').textContent = carta.contenido;
  modal.classList.add('show');
  document.getElementById('letter-close').focus();
  document.addEventListener('keydown', onKeydown);
}
function closeLetter(){
  modal.classList.remove('show');
  document.removeEventListener('keydown', onKeydown);
  if(lastFocused) lastFocused.focus();
}
function onKeydown(e){ if(e.key === 'Escape') closeLetter(); }
document.getElementById('letter-close').addEventListener('click', closeLetter);
modal.addEventListener('click', (e) => { if(e.target === modal) closeLetter(); });

/* ---------- reveal on scroll ---------- */
const revealEls = document.querySelectorAll('.reveal');
if(REDUCED_MOTION){
  revealEls.forEach(el => el.classList.add('in-view'));
} else {
  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if(entry.isIntersecting){
        entry.target.classList.add('in-view');
        io.unobserve(entry.target);
      }
    });
  }, {threshold:.15});
  revealEls.forEach(el => io.observe(el));
}

/* ============================================================
   REPRODUCTOR DE AUDIO
   ============================================================ */
const TRACKS = [


const audio = new Audio();
let currentTrack = 0;
let isPlaying = false;

const els = {
  vinyl: document.getElementById('vinyl'),
  miniVinyl: document.getElementById('mini-vinyl'),
  nowTitle: document.getElementById('now-title'),
  nowArtist: document.getElementById('now-artist'),
  miniTitle: document.getElementById('mini-title'),
  miniArtist: document.getElementById('mini-artist'),
  seek: document.getElementById('seek'),
  timeCur: document.getElementById('time-cur'),
  timeDur: document.getElementById('time-dur'),
  btnPlay: document.getElementById('btn-play'),
  iconPlay: document.getElementById('icon-play'),
  iconPause: document.getElementById('icon-pause'),
  miniPlay: document.getElementById('mini-play'),
  miniIconPlay: document.getElementById('mini-icon-play'),
  miniIconPause: document.getElementById('mini-icon-pause'),
  miniplayer: document.getElementById('miniplayer'),
  tracklist: document.getElementById('tracklist'),
};

function fmtTime(sec){
  if(!isFinite(sec) || sec < 0) sec = 0;
  const m = Math.floor(sec/60);
  const s = Math.floor(sec%60);
  return m + ':' + pad(s);
}

function buildTracklist(){
  TRACKS.forEach((t, i) => {
    const row = document.createElement('div');
    row.className = 'track-row' + (i===currentTrack ? ' active' : '');
    row.innerHTML = `
      <span class="idx">${i+1}</span>
      <div class="names">
        <div class="n-title">${t.title}</div>
        <div class="n-artist">${t.artist}</div>
      </div>
      <span class="eq"><span></span><span></span><span></span></span>
    `;
    row.addEventListener('click', () => { loadTrack(i); playAudio(); });
    els.tracklist.appendChild(row);
  });
}

function refreshTracklistActive(){
  [...els.tracklist.children].forEach((row, i) => {
    row.classList.toggle('active', i === currentTrack);
  });
}

function loadTrack(i){
  currentTrack = (i + TRACKS.length) % TRACKS.length;
  const t = TRACKS[currentTrack];
  audio.src = t.src;
  els.nowTitle.textContent = t.title;
  els.nowArtist.textContent = t.artist;
  els.miniTitle.textContent = t.title;
  els.miniArtist.textContent = t.artist;
  refreshTracklistActive();
}

function playAudio(){
  audio.play();
}
function pauseAudio(){
  audio.pause();
}

audio.addEventListener('play', () => {
  isPlaying = true;
  els.iconPlay.style.display = 'none';
  els.iconPause.style.display = '';
  els.miniIconPlay.style.display = 'none';
  els.miniIconPause.style.display = '';
  els.vinyl.classList.add('spinning');
  els.miniVinyl.classList.add('spinning');
  els.miniplayer.classList.add('show');
});
audio.addEventListener('pause', () => {
  isPlaying = false;
  els.iconPlay.style.display = '';
  els.iconPause.style.display = 'none';
  els.miniIconPlay.style.display = '';
  els.miniIconPause.style.display = 'none';
  els.vinyl.classList.remove('spinning');
  els.miniVinyl.classList.remove('spinning');
});
audio.addEventListener('loadedmetadata', () => {
  els.seek.max = Math.floor(audio.duration) || 0;
  els.timeDur.textContent = fmtTime(audio.duration);
});
audio.addEventListener('timeupdate', () => {
  if(!els.seek.matches(':active')){
    els.seek.value = Math.floor(audio.currentTime);
  }
  els.timeCur.textContent = fmtTime(audio.currentTime);
});
audio.addEventListener('ended', () => {
  loadTrack(currentTrack + 1);
  playAudio();
});

els.seek.addEventListener('input', () => {
  audio.currentTime = Number(els.seek.value);
});

function togglePlay(){
  if(isPlaying) pauseAudio(); else playAudio();
}
els.btnPlay.addEventListener('click', togglePlay);
els.miniPlay.addEventListener('click', togglePlay);
document.getElementById('btn-prev').addEventListener('click', () => { loadTrack(currentTrack - 1); playAudio(); });
document.getElementById('btn-next').addEventListener('click', () => { loadTrack(currentTrack + 1); playAudio(); });
els.miniplayer.addEventListener('click', (e) => {
  if(e.target.closest('button')) return;
  document.getElementById('playlist').scrollIntoView({behavior: REDUCED_MOTION ? 'auto' : 'smooth'});
});

buildTracklist();
loadTrack(0);
</script>
